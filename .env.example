# === GitHub (for storage) ===
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=your-username/zumo-data
GITHUB_BRANCH=main

# === Speaker Diarization (pyannote-audio) ===
# Get token: https://huggingface.co/settings/tokens
# Accept model terms: https://huggingface.co/pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=hf_your_token_here

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_bot_token_here

# === Dashboard (optional) ===
# GitHub Pages: https://your-username.github.io/zumo-data
# DASHBOARD_BASE_URL=https://your-username.github.io/zumo-data

# === User Config (for containerized deploys like Railway) ===
# JSON object mapping username to config. Only needed if users/*.json are not in the image.
# USERS_CONFIG={"ben-akiva":{"name":"Ben Akiva","telegram_user_id":123456,"hebrew_ai_api_key":"sk_...","anthropic_api_key":"sk-ant-...","default_language":"he","silence_threshold_seconds":30,"dashboard_slug":"ben-akiva"}}
